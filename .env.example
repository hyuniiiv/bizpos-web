# ================================
# BIZPOS WEB - 환경변수 설정 가이드
# ================================
# 이 파일을 복사하여 .env.local 로 저장 후 실제 값 입력

# ---- Supabase (클라우드 데이터베이스) ----
# Supabase 프로젝트 설정: https://supabase.com → Project Settings → API
# 모든 클라이언트/서버에서 사용되는 공개 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 클라이언트 측 인증 키 (공개적으로 노출 가능)
# Supabase 대시보드에서 복사 가능
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 서버 측 관리자 키 (보안: 서버에서만 사용, 절대 클라이언트로 전송 금지)
# API Route에서 RLS(Row Level Security) 우회 시에만 사용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- 단말기 JWT 서명 ----
# 단말기(POS 터미널) JWT 토큰 생성/검증용 시크릿 키
# 최소 32자 이상의 랜덤 문자열 권장
# 명령: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TERMINAL_JWT_SECRET=your-random-32-char-secret-key-here

# ---- 비플페이 결제 API ----
# 비플페이 PG(결제게이트웨이) 서비스 설정
# 개발 환경: https://pgapi-dev.bizplaypay.co.kr
# 운영 환경: https://pgapi.bizplaypay.co.kr
BIZPLAY_BASE_URL=https://pgapi-dev.bizplaypay.co.kr

# 비플페이 가맹점 ID (MID)
# 결제 API 요청 시 필수
BIZPLAY_MID=your-merchant-id

# 비플페이 온라인 API 인증 키
# 형식: "OnlineAK {api-key}"
# API 요청 암호화/복호화에 사용
BIZPLAY_ONLINE_AK=OnlineAK your-api-key-here

# ---- 내부 API 보안 ----
# 로컬 POS 전용 API 라우트 보호용 내부 키
# 파일시스템 기반 로컬 저장소 접근 시 필수
# Vercel(클라우드) 배포 환경에서는 설정하지 않음
INTERNAL_POS_KEY=your-internal-api-key-here

# 로컬 파일 저장 디렉토리 (기본값: {프로젝트루트}/data)
# Electron 환경에서 실행 파일 위치에 맞게 조정 가능
DATA_DIR=

# ---- 애플리케이션 설정 ----
# Node.js 실행 환경
# 값: development, production
NODE_ENV=development

# 애플리케이션 공개 URL
# 인증 콜백, CORS, 외부 서비스 연동 시 사용
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ================================
# 세팅 가이드
# ================================
#
# 개발 환경 (로컬)
# ─────────────────
# 1. .env.local 파일 생성 (이 파일 복사)
# 2. 모든 값 입력
# 3. npm run dev 로 시작
#
# 운영 환경 (Vercel)
# ─────────────────
# 1. Vercel 대시보드 → Settings → Environment Variables
# 2. NEXT_PUBLIC_* 변수들 입력 (클라이언트에 노출됨)
# 3. SUPABASE_SERVICE_ROLE_KEY 입력 (서버 전용)
# 4. INTERNAL_POS_KEY 미설정 (로컬 전용)
# 5. BIZPLAY_* 변수들 입력
#
# 보안 주의사항
# ─────────────
# - SUPABASE_SERVICE_ROLE_KEY: 절대 클라이언트로 노출 금지
# - TERMINAL_JWT_SECRET: 정기적으로 로테이션 권장
# - BIZPLAY_ONLINE_AK: 비플페이에서 안전하게 관리
# - INTERNAL_POS_KEY: 로컬 개발 환경에서만 사용
# - Git 커밋 전에 .env.local 을 .gitignore에 포함시켰는지 확인
