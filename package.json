{
  "name": "bizpos-web",
  "version": "0.1.71",
  "description": "BIZPOS - POS Terminal Application",
  "author": "BIZPLAY",
  "license": "UNLICENSED",
  "homepage": "./",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "node scripts/electron-build-wrapper.js",
    "electron:build": "node scripts/electron-build-wrapper.js && electron-builder",
    "electron:build:win": "node scripts/electron-build-wrapper.js && electron-builder --win",
    "electron:pack": "electron-builder --dir",
    "electron:release": "node scripts/electron-build-wrapper.js && electron-builder --win --publish always"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
